        "00:00:27.50": {
            "segment_index": 10,
            "start": 27.5,
            "end": 32.8,
            "duration": 5.3,
            "text": "바로 시업 준비와 아르바이트를 병해하는 글로 빈곤자 약 400만 명인데요.",
            "speech_rate_cps": 7.736,
            "prosody": {
